@article{HundMlinaricSaak2018,
 abstract = {So far, {$\mathcal{H}_2 \otimes \mathcal{L}_2$}-optimal model
order reduction (MOR) of linear time-invariant systems,
preserving the affine parameter dependence, was only considered
for special cases by Baur et al in 2011. In this contribution,
we present necessary conditions for an {$\mathcal{H}_2 \otimes
\mathcal{L}_2$}-optimal parametric reduced order model, for
general affine parametric systems resembling the special case
investigated by Baur et al.},
 author = {Manuela Hund and Petar Mlinari{\'c} and Jens Saak},
 doi = {10.1002/pamm.201800084},
 journal = {Proc. Appl. Math. Mech.},
 month = {December},
 number = {1},
 title = {An {$\mathcal{H}_2 \otimes \mathcal{L}_2$}-Optimal Model Order
Reduction Approach for Parametric Linear Time-Invariant
Systems},
 volume = {18},
 year = {2018}
}
