@article{BalickiMlinaricRaveSaak2019,
 abstract = {This paper shows recent developments in pyMOR, in particular
the addition of system-theoretic methods. All methods are
implemented using pyMOR's abstract interfaces, which allows the
application to partial differential equation (PDE) models
implemented with third-party libraries. We demonstrate this by
applying balanced truncation to a PDE model discretized in
FEniCS.},
 author = {Linus Balicki and Petar Mlinari{\'c} and Stephan Rave and Jens
Saak},
 doi = {10.1002/pamm.201900459},
 journal = {Proc. Appl. Math. Mech.},
 month = {November},
 number = {1},
 title = {System-theoretic model order reduction with {pyMOR}},
 volume = {19},
 year = {2019}
}
