@inproceedings{MlinaricGrundelBenner2016,
 abstract = {In this paper, we extend our clustering-based model order
reduction method for multi-agent systems with single-integrator
agents to the case where the agents have identical general
linear time-invariant dynamics. The method consists of the
Iterative Rational Krylov Algorithm, for finding a good reduced
order model, and the QR decomposition-based clustering
algorithm, to achieve structure preservation by clustering
agents. Compared to the case of single-integrator agents, we
modified the QR decomposition with column pivoting inside the
clustering algorithm to take into account the block-column
structure. We illustrate the method on small and large-scale
examples.},
 address = {Minneapolis, MN, USA},
 author = {Petar Mlinari{\'c} and Sara Grundel and Peter Benner},
 booktitle = {22nd International Symposium on Mathematical Theory of
Networks and Systems (MTNS)},
 month = {July},
 pages = {230--235},
 title = {Clustering-Based Model Order Reduction for Multi-Agent Systems
with General Linear Time-Invariant Agents},
 url = {http://hdl.handle.net/11299/181518},
 year = {2016}
}
