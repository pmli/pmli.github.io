@article{BennerGrundelMlinaric2016,
 abstract = {We develop a stability preserving model reduction method for
linearly coupled linear time-invariant (LTI) systems. The
method extends the work of Monshizadeh et al. for multi-agent
systems with identical LTI agents. They propose using Bounded
Real Balanced Truncation to preserve a sufficient condition for
stability of the coupled system. Here, we extend this idea to
arbitrary linearly coupled LTI systems using the sufficient
condition for stability introduced by Reis and Stykel. The
model reduction error bounds for this method also follow from
results of Reis and Stykel, which allows the adaptive choice of
reduced orders. We demonstrate the method on Reis's and
Stykel's coupled string-beam example.},
 author = {Peter Benner and Sara Grundel and Petar Mlinari{\'c}},
 doi = {10.1002/pamm.201610397},
 journal = {Proc. Appl. Math. Mech.},
 month = {October},
 number = {1},
 pages = {817--818},
 title = {Stability preserving model reduction for linearly coupled
linear time-invariant systems},
 volume = {16},
 year = {2016}
}
