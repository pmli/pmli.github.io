@incollection{BennerGrundelMlinaric2021,
 abstract = {Clustering by projection has been proposed as a way to
preserve network structure in linear multi-agent systems. Here,
we extend this approach to a class of nonlinear network
systems. Additionally, we generalize our clustering method
which restores the network structure in an arbitrary
reduced-order model obtained by projection. We demonstrate this
method on a number of examples.},
 author = {Peter Benner and Sara Grundel and Petar Mlinari{\'c}},
 booktitle = {Model Reduction of Complex Dynamical Systems},
 doi = {10.1007/978-3-030-72983-7_4},
 editor = {Peter Benner and Tobias Breiten and Heike Fa{\ss}bender and
Michael Hinze and Tatjana Stykel and Ralf Zimmermann},
 month = {August},
 pages = {75--96},
 publisher = {Birkh{\"a}user, Cham},
 series = {International Series of Numerical Mathematics},
 title = {Clustering-Based Model Order Reduction for Nonlinear Network
Systems},
 volume = {171},
 year = {2021}
}
